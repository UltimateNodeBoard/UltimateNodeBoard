<span class="unb-group-badge" style="--badge-text-color: <% if (badge.themeMode === 'light') { %><%= badge.color.light.normal.text %><% } else { %><%= badge.color.dark.normal.text %><% } %>; --badge-text-hover-color: <% if (badge.themeMode === 'light') { %><%= badge.color.light.hover.text %><% } else { %><%= badge.color.dark.hover.text %><% } %>; --badge-bg-color: <% if (badge.themeMode === 'light') { %><%= badge.color.light.normal.background %><% } else { %><%= badge.color.dark.normal.background %><% } %>; --badge-bg-hover-color: <% if (badge.themeMode === 'light') { %><%= badge.color.light.hover.background %><% } else { %><%= badge.color.dark.hover.background %><% } %>;">
    <a href="<%= badge.url %>"><i class="<%= badge.icon %>"></i><%= badge.name %></a>
</span>